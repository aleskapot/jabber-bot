{
  "name": "n8n-nodes-jabber-bot",
  "version": "1.1.0",
  "description": "Jabber Bot XMPP integration for n8n - Send messages and files via XMPP",
  "keywords": [
    "n8n-nodes",
    "jabber",
    "xmpp",
    "chat",
    "messaging",
    "n8n-community-node-package"
  ],
  "license": "MIT",
  "homepage": "https://github.com/aleskapot/jabber-bot",
  "author": {
    "name": "aleskapot"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aleskapot/jabber-bot"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');fs.cpSync('src/icons','dist/icons',{recursive:true});fs.mkdirSync('dist/nodes/JabberBot/icons',{recursive:true});fs.cpSync('src/icons','dist/nodes/JabberBot/icons',{recursive:true});fs.mkdirSync('dist/credentials/icons',{recursive:true});fs.cpSync('src/icons','dist/credentials/icons',{recursive:true})\"",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --ext .ts --fix"
  },
  "n8n": {
    "nodes": [
      "dist/nodes/JabberBot/JabberBot.node.js",
      "dist/nodes/JabberBot/JabberBotTrigger.node.js"
    ],
    "credentials": [
      "dist/credentials/JabberBotApi.credentials.js"
    ]
  },
  "dependencies": {
    "n8n-workflow": "^2.0.0",
    "form-data": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.10.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "eslint": "^10.0.0",
    "globals": "^17.5.0",
    "typescript": "^5.3.0"
  }
}